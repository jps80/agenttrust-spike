# --- Servicios (puertos) ---
ISSUER_PORT=8000
VERIFIER_PORT=8001
REGISTRY_UI_PORT=8002

# --- URLs públicas (lo que ven los demás servicios) ---
ISSUER_BASE_URL=http://localhost:8000
VERIFIER_BASE_URL=http://localhost:8001
REGISTRY_UI_BASE_URL=http://localhost:8002

# --- Identidad de la organización emisora (mock Business Wallet) ---
# El did:web se construye como did:web:<host>:<path opcional>
# En el spike, did:web:localhost%3A8000 (el %3A es ":" url-encoded)
ORG_DID=did:web:localhost%3A8000
ORG_LEGAL_NAME=Banco de Pruebas SA
ORG_CIF=A12345678

# --- Custodia de claves ---
# "local" o "vault"
KEY_CUSTODY_BACKEND=local

# --- LocalFile custody ---
LOCAL_KEY_DIR=./data/keys

# --- Vault custody ---
VAULT_ADDR=http://localhost:8200
VAULT_TOKEN=root-token-spike
VAULT_TRANSIT_MOUNT=transit

# --- Persistencia ---
SQLITE_PATH=./data/agenttrust.db
